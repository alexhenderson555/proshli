# ---------------------------------------------------------------------------
# Otklik.ai — production environment template (root compose / Yandex Cloud).
# Single source for all services. Per-app .env.example files document the
# minimum each service needs in dev.
# ---------------------------------------------------------------------------

# --- App --------------------------------------------------------------------
APP_ENV=production
APP_LOG_LEVEL=INFO
APP_BASE_URL=https://otklik.ai

# --- Postgres ---------------------------------------------------------------
POSTGRES_DB=otklik
POSTGRES_USER=otklik
POSTGRES_PASSWORD=change-me-strong-password

# --- Auth -------------------------------------------------------------------
JWT_SECRET=change-me-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=20160

# --- AI ---------------------------------------------------------------------
AI_DAILY_REQUEST_LIMIT=25
AI_MAX_INPUT_CHARS=1000
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# --- ЮKassa (Wave 2) --------------------------------------------------------
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# --- Telegram ---------------------------------------------------------------
BOT_SERVICE_KEY=change-me-bot-service-key
TELEGRAM_BOT_TOKEN=

# --- Ingestion --------------------------------------------------------------
RSS_SOURCE_URLS=

# --- SMTP (digest fallback, Sprint 3) --------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@otklik.ai

# --- Observability ----------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
