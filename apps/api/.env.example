# ---------------------------------------------------------------------------
# Otklik.ai — API environment template.
# Copy to `.env` for local dev. Production values come from the deploy host.
# ---------------------------------------------------------------------------

# --- App -------------------------------------------------------------------
APP_ENV=development               # development | test | staging | production
APP_LOG_LEVEL=INFO

# --- Database --------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://otklik:otklik@localhost:5432/otklik
AUTO_CREATE_SCHEMA=false          # Tests flip this on via conftest

# --- Redis / Celery --------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Auth ------------------------------------------------------------------
JWT_SECRET=change-me-in-prod-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=20160      # 14 days

# --- Telegram bot ----------------------------------------------------------
BOT_SERVICE_KEY=change-me-bot-service-key
TELEGRAM_BOT_TOKEN=
TELEGRAM_LINK_CODE_TTL_MINUTES=15

# --- AI guardrails ---------------------------------------------------------
AI_DAILY_REQUEST_LIMIT=25
AI_MAX_INPUT_CHARS=1000

# --- Anthropic Claude (Wave 3) --------------------------------------------
# Leave empty in dev: /ai/chat falls back to the rule-based extractor.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_MAX_TOKENS=1024

# --- ЮKassa billing (Wave 2) ----------------------------------------------
# Get these from https://yookassa.ru/my (Магазин → API ключи).
# Test shop creds work for local dev — see https://yookassa.ru/developers/using-api/testing.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
APP_BASE_URL=http://localhost:3000

# --- Ingestion sources -----------------------------------------------------
RSS_SOURCE_URLS=                   # comma-separated list
HH_BASE_URL=https://api.hh.ru
HH_SEARCH_TEXT=python developer
HH_REGION=113                      # 113 = Russia
HH_PER_PAGE=20
HH_LIVE_ENABLED=true
HH_LIVE_LIMIT=30

# --- SMTP (digest delivery fallback) ---------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@otklik.local

# --- Observability ---------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- CORS ------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
