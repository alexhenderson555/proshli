@app.post("/ingest/{source_name}", response_model=IngestRunOut)
def ingest_source(
    source_name: str,
    current_user: User = Depends(get_current_user),
    db: Session = Depends(get_db),
) -> IngestRunOut:
    if current_user.role != "employer":
        raise HTTPException(status_code=403, detail="Only employers can run source ingestion")

    connectors = connector_map()
    connector = connectors.get(source_name)
    if not connector:
        raise HTTPException(status_code=404, detail="Unknown source")

    payloads = connector.fetch()
    run = run_ingestion(db, source_name=source_name, payloads=payloads)
    return run


@app.get("/sources", response_model=list[SourceConnectorOut])
def list_sources() -> list[SourceConnectorOut]:
    return [SourceConnectorOut(name=name) for name in sorted(connector_map().keys())]


@app.get("/digest/preview", response_model=DigestPreviewOut)
def preview_digest(
    current_user: User = Depends(get_current_user),
    db: Session = Depends(get_db),
) -> DigestPreviewOut:
    pref = db.scalar(select(DigestPreference).where(DigestPreference.user_id == current_user.id))
    if not pref:
        pref = DigestPreference(user_id=current_user.id, frequency="daily", via_telegram=True, via_email=False)
        db.add(pref)
        db.commit()
        db.refresh(pref)

    ranked = rank_for_user(db, current_user, limit=10)
    items = [
        DigestItem(
            vacancy_id=item.vacancy.id,
            title=item.vacancy.title,
            company=item.vacancy.company,
            location=item.vacancy.location,
            score_reason=item.reason,
        )
        for item in ranked
    ]
    return DigestPreviewOut(frequency=pref.frequency, channels=digest_channels(pref), items=items)


@app.post("/admin/run-scheduler", response_model=SchedulerRunOut)
def run_scheduler_once(
    frequency: str = Query(default="daily"),
    current_user: User = Depends(get_current_user),
    db: Session = Depends(get_db),
) -> SchedulerRunOut:
    if current_user.role != "employer":
        raise HTTPException(status_code=403, detail="Only employers can run scheduler")
    if frequency not in {"daily", "weekly"}:
        raise HTTPException(status_code=400, detail="frequency must be daily or weekly")
    result = run_once(db, digest_frequency=frequency)
    return SchedulerRunOut(**result.__dict__)


@app.put("/profiles/seeker", response_model=SeekerProfileOut)
def upsert_seeker_profile(
    payload: SeekerProfileUpdate,
    current_user: User = Depends(get_current_user),
    db: Session = Depends(get_db),
) -> SeekerProfileOut:
    if current_user.role != "seeker":
        raise HTTPException(status_code=403, detail="Only seekers can edit seeker profile")

    profile = db.scalar(select(SeekerProfile).where(SeekerProfile.user_id == current_user.id))
    if not profile:
        profile = SeekerProfile(user_id=current_user.id)
        db.add(profile)
        db.commit()
        db.refresh(profile)

    profile.full_name = payload.full_name
    profile.target_role = payload.target_role
    profile.location = payload.location
    profile.about = payload.about
    profile.skills_csv = ", ".join(payload.skills)
    profile.updated_at = now_utc()
    db.commit()
    db.refresh(profile)

    return SeekerProfileOut(
        full_name=profile.full_name,
        target_role=profile.target_role,
        location=profile.location,
        about=profile.about,
        skills=[s.strip() for s in profile.skills_csv.split(",") if s.strip()],
        updated_at=profile.updated_at,
    )


