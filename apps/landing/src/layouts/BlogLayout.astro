---
import BaseLayout from "./BaseLayout.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const formattedDate = post.data.publishDate.toLocaleDateString("ru-RU", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<BaseLayout title={`${post.data.title} — Блог Proshli`} description={post.data.description}>
  <article class="mx-auto max-w-3xl px-6 py-24">
    <a href="/blog" class="text-13 text-landing-text-muted hover:text-landing-text-primary transition-colors">&larr; Все статьи</a>
    <h1 class="text-24 md:text-32 font-extrabold tracking-tight mt-6 mb-3">{post.data.title}</h1>
    <div class="flex items-center gap-3 text-12 text-landing-text-muted mb-12">
      <span>{formattedDate}</span>
      {post.data.tags.length > 0 && <span>&middot;</span>}
      {post.data.tags.map((t) => (
        <span class="px-2 py-0.5 rounded-full border border-white/8">{t}</span>
      ))}
    </div>
    <div class="prose prose-invert prose-lg max-w-none prose-p:text-landing-text-muted prose-p:leading-loose prose-headings:text-landing-text-primary prose-a:text-landing-accent-start prose-strong:text-landing-text-primary prose-code:text-landing-accent-start prose-code:text-13">
      <slot />
    </div>
  </article>
</BaseLayout>
