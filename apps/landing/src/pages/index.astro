---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroAiDemo from "../components/HeroAiDemo.tsx";
import InteractiveSpace from "../components/InteractiveSpace.tsx";
import TelegramMockup from "../components/TelegramMockup.astro";
import Testimonials from "../components/Testimonials.astro";
import PricingCard from "../components/PricingCard.astro";
import FaqItem from "../components/FaqItem.astro";
import AnimatedCounter from "../components/AnimatedCounter.tsx";
import TimeCalculator from "../components/TimeCalculator.tsx";
import GlowCard from "../components/GlowCard.tsx";
import { tiers } from "../lib/tiers";
---

<BaseLayout title="Proshli — AI читает вакансии, ты не читаешь" description="Семантический AI-поиск IT-вакансий. Опиши что ищешь словами — AI найдёт матчи по резюме и пришлёт дайджест в Telegram.">
  <!-- ═══ Hero Section ═══ -->
  <section class="relative min-h-[calc(100vh-3.5rem)] flex items-center px-6 overflow-hidden font-sans">
    <InteractiveSpace client:load />
    
    <div class="mx-auto max-w-6xl w-full grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center py-20 relative z-10">
      <div>
        {/* Glow pill badge */}
        <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-white/[0.08] bg-white/[0.02] mb-6 shadow-sm hover:border-white/25 hover:bg-white/[0.05] transition-all duration-300">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-400"></span>
          </span>
          <span class="text-11 font-mono tracking-wider text-landing-text-muted/90 uppercase">
            База обновлена 12 мин назад • 12 847 активных вакансий
          </span>
        </div>

        <h1 class="text-40 md:text-56 lg:text-72 font-bold tracking-tight leading-[1.05] text-white">
          AI читает вакансии,<br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-landing-accent-start via-purple-300 to-landing-accent-end">
            ты не читаешь
          </span>
        </h1>
        
        <p class="mt-6 text-15 md:text-17 text-landing-text-muted leading-relaxed max-w-xl">
          Хватит листать бесконечные ленты с мусором и бороться с глупыми фильтрами. Наш AI анализирует векторное совпадение вакансий с твоим резюме по смыслу, отсеивает 95% нерелевантного шума и присылает лучшие матчи в Telegram. Каждое утро.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row items-stretch sm:items-center gap-4">
          <a
            href="https://app.proshli.ru/auth/register"
            class="inline-flex items-center justify-center h-12 px-8 rounded-xl bg-gradient-to-r from-landing-accent-start to-landing-accent-end text-14 font-medium text-white shadow-glow hover:opacity-95 active:scale-[0.98] transition-all duration-200"
          >
            Запустить поиск бесплатно
            <svg class="ml-2 w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
          </a>
          <a 
            href="#how-it-works" 
            class="inline-flex items-center justify-center h-12 px-6 rounded-xl border border-white/10 hover:border-white/20 bg-white/[0.02] hover:bg-white/[0.05] text-14 text-white font-medium transition-all duration-200"
          >
            Как это работает
          </a>
        </div>

        {/* Minimal trust indicator */}
        <div class="mt-10 flex items-center gap-3 text-12 text-landing-text-muted/70">
          <div class="flex -space-x-2">
            <span class="w-6 h-6 rounded-full bg-violet-600 border border-[#070708] flex items-center justify-center text-[10px] font-bold text-white">JD</span>
            <span class="w-6 h-6 rounded-full bg-indigo-600 border border-[#070708] flex items-center justify-center text-[10px] font-bold text-white">MK</span>
            <span class="w-6 h-6 rounded-full bg-emerald-600 border border-[#070708] flex items-center justify-center text-[10px] font-bold text-white">AL</span>
          </div>
          <span>Присоединяйся к 2 400+ разработчикам, которые уже делегировали поиск AI</span>
        </div>
      </div>

      <div class="relative">
        <div class="absolute -inset-1 rounded-2xl bg-gradient-to-tr from-landing-accent-start to-indigo-500 opacity-20 blur-lg pointer-events-none"></div>
        <HeroAiDemo client:load />
      </div>
    </div>
  </section>

  <!-- ═══ Logos Cloud / trust bar ═══ -->
  <section class="py-16 px-6 border-t border-white/[0.06] bg-[#070708]/50">
    <div class="mx-auto max-w-6xl">
      <p class="text-center text-11 font-mono text-white/30 uppercase tracking-widest mb-8">
        Агрегируем вакансии с более чем 50 источников
      </p>
      <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-6 opacity-40 hover:opacity-60 transition-opacity duration-300 font-mono">
        <span class="text-16 font-bold text-white tracking-widest">HEADHUNTER</span>
        <span class="text-16 font-bold text-white tracking-widest">HABR_CAREER</span>
        <span class="text-16 font-bold text-white tracking-widest">LINKEDIN</span>
        <span class="text-16 font-bold text-white tracking-widest">TELEGRAM_CHANNELS</span>
        <span class="text-16 font-bold text-white tracking-widest">GETMATCH</span>
        <span class="text-13 font-semibold text-landing-accent-start tracking-wider">AND_30+_OTHERS</span>
      </div>
    </div>
  </section>

  <!-- ═══ Bento Grid: Features ═══ -->
  <section id="features" class="py-32 px-6 border-t border-white/[0.06] relative">
    <div class="mx-auto max-w-6xl">
      <div class="text-center max-w-3xl mx-auto mb-20">
        <span class="text-11 font-mono uppercase tracking-wider text-landing-accent-start bg-landing-accent-start/10 border border-landing-accent-start/20 px-3 py-1 rounded-full">
          Движок, который заменяет 10 часов скроллинга
        </span>
        <h2 class="text-32 md:text-48 font-bold tracking-tight text-white mt-4">
          Поиск работы на автопилоте.<br />
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-white via-purple-200 to-purple-400">Всю рутину мы забрали себе</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        
        {/* Bento Card 1: Vector similarity (Span 7) */}
        <GlowCard client:load className="col-span-1 md:col-span-7 p-8 min-h-[380px]">
          <div>
            <div class="w-10 h-10 rounded-xl bg-landing-accent-start/15 border border-landing-accent-start/20 flex items-center justify-center mb-6">
              <svg class="w-5 h-5 text-landing-accent-start" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg>
            </div>
            <h3 class="text-20 font-bold text-white tracking-tight">1024-мерные эмбеддинги резюме</h3>
            <p class="text-13 text-landing-text-muted mt-2 leading-relaxed max-w-md">
              Обычный поиск ищет совпадение по тексту. Наш AI переводит резюме и вакансии в 1024-мерные векторы, анализируя реальный смысл опыта, навыков и контекста.
            </p>
          </div>

          {/* SVG Vector Nodes Grid Animation */}
          <div class="mt-6 border border-white/[0.06] rounded-xl bg-black/40 p-4 h-36 flex items-center justify-center relative overflow-hidden">
            <svg class="w-full h-full max-w-sm" viewBox="0 0 400 120">
              <circle cx="50" cy="60" r="4" class="fill-landing-accent-start/60 animate-ping"></circle>
              <circle cx="50" cy="60" r="4" class="fill-landing-accent-start"></circle>
              
              <circle cx="150" cy="30" r="3" class="fill-indigo-400"></circle>
              <circle cx="150" cy="90" r="3" class="fill-indigo-400"></circle>
              
              <circle cx="250" cy="40" r="3" class="fill-purple-400"></circle>
              <circle cx="250" cy="80" r="3" class="fill-purple-400"></circle>
              
              <circle cx="350" cy="60" r="4" class="fill-landing-accent-end/60 animate-ping"></circle>
              <circle cx="350" cy="60" r="4" class="fill-landing-accent-end"></circle>

              {/* Connecting lines */}
              <line x1="50" y1="60" x2="150" y2="30" stroke="rgba(255,255,255,0.06)" stroke-dasharray="4" class="animate-[dash_10s_linear_infinite]"></line>
              <line x1="50" y1="60" x2="150" y2="90" stroke="rgba(255,255,255,0.06)"></line>
              <line x1="150" y1="30" x2="250" y2="40" stroke="rgba(255,255,255,0.06)"></line>
              <line x1="150" y1="90" x2="250" y2="80" stroke="rgba(255,255,255,0.06)"></line>
              <line x1="250" y1="40" x2="350" y2="60" stroke="rgba(255,255,255,0.06)"></line>
              <line x1="250" y1="80" x2="350" y2="60" stroke="rgba(255,255,255,0.06)" stroke-dasharray="4"></line>

              {/* Dynamic matching glow text */}
              <text x="200" y="65" text-anchor="middle" class="fill-white/60 font-mono text-[10px]" font-weight="bold">Similarity Score: 94.2%</text>
            </svg>
          </div>
        </GlowCard>

        {/* Bento Card 2: 50+ Sources (Span 5) */}
        <GlowCard client:load className="col-span-1 md:col-span-5 p-8 min-h-[380px]">
          <div>
            <div class="w-10 h-10 rounded-xl bg-indigo-500/15 border border-indigo-500/20 flex items-center justify-center mb-6">
              <svg class="w-5 h-5 text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" /></svg>
            </div>
            <h3 class="text-20 font-bold text-white tracking-tight">Единая лента из 50+ источников</h3>
            <p class="text-13 text-landing-text-muted mt-2 leading-relaxed">
              Мы собираем вакансии отовсюду: от крупных ресурсов hh/Хабр до небольших IT Telegram-каналов и редких карьерных порталов корпораций.
            </p>
          </div>

          <div class="mt-6 flex flex-wrap gap-2.5">
            <span class="text-11 font-mono px-3 py-1.5 rounded-lg border border-white/[0.06] bg-white/[0.01] text-white/70">HeadHunter API</span>
            <span class="text-11 font-mono px-3 py-1.5 rounded-lg border border-white/[0.06] bg-white/[0.01] text-white/70">Habr Careers</span>
            <span class="text-11 font-mono px-3 py-1.5 rounded-lg border border-white/[0.06] bg-white/[0.01] text-white/70">Telegram Scraper</span>
            <span class="text-11 font-mono px-3 py-1.5 rounded-lg border border-white/[0.06] bg-white/[0.01] text-white/70">LinkedIn XML</span>
            <span class="text-11 font-mono px-3 py-1.5 rounded-lg border border-white/[0.06] bg-white/[0.01] text-white/70">GetMatch Feed</span>
            <span class="text-11 font-mono px-3 py-1.5 rounded-lg border border-white/[0.06] bg-white/[0.01] text-landing-accent-start font-semibold">И ещё 45+ источников</span>
          </div>
        </GlowCard>

        {/* Bento Card 3: Deep AI Reasoning (Span 5) */}
        <GlowCard client:load className="col-span-1 md:col-span-5 p-8 min-h-[380px]">
          <div>
            <div class="w-10 h-10 rounded-xl bg-purple-500/15 border border-purple-500/20 flex items-center justify-center mb-6">
              <svg class="w-5 h-5 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
            </div>
            <h3 class="text-20 font-bold text-white tracking-tight">Match-score с обоснованием</h3>
            <p class="text-13 text-landing-text-muted mt-2 leading-relaxed">
              AI не просто выдает процент, а человеческим языком объясняет, почему вакансия подходит и какие есть скрытые риски по твоему стеку.
            </p>
          </div>

          <div class="mt-6 border border-white/[0.06] rounded-xl bg-black/40 p-4 font-mono text-[11px] space-y-2">
            <div class="text-emerald-400 font-semibold">• Плюсы: Сильное пересечение по Go, Kafka, PostgreSQL.</div>
            <div class="text-yellow-400 font-semibold">• Риски: Требуют опыт с Kubernetes, у вас в резюме указан только базовый Docker.</div>
            <div class="text-white/40">• Стек компании: Go, Kafka, K8s, gRPC.</div>
          </div>
        </GlowCard>

        {/* Bento Card 4: Telegram Integration (Span 7) */}
        <GlowCard client:load className="col-span-1 md:col-span-7 p-8 min-h-[380px]">
          <div>
            <div class="w-10 h-10 rounded-xl bg-emerald-500/15 border border-emerald-500/20 flex items-center justify-center mb-6">
              <svg class="w-5 h-5 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" /></svg>
            </div>
            <h3 class="text-20 font-bold text-white tracking-tight">Ежедневный Telegram Дайджест</h3>
            <p class="text-13 text-landing-text-muted mt-2 leading-relaxed max-w-md">
              Никаких личных кабинетов, куда нужно заходить каждый день. Раз в день бот присылает компактный список матчей и позволяет откликнуться прямо из мессенджера.
            </p>
          </div>

          {/* Simple Push Notification Mockup */}
          <div class="mt-6 border border-white/[0.06] rounded-xl bg-black/60 p-4 flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-landing-accent-start flex items-center justify-center text-11 font-bold text-white">P</div>
            <div class="flex-1">
              <div class="text-12 font-bold text-white flex justify-between">
                <span>Proshli Bot</span>
                <span class="text-white/30 text-[10px] font-normal">Сейчас</span>
              </div>
              <div class="text-11 text-white/70 mt-0.5">Утренний дайджест: найдено 3 релевантных вакансии по Go Backend.</div>
            </div>
          </div>
        </GlowCard>

      </div>
    </div>
  </section>

  <!-- ═══ Compare & Calculator Section ═══ -->
  <section class="py-32 px-6 border-t border-white/[0.06] bg-[#070708]/30">
    <div class="mx-auto max-w-5xl">
      <div class="text-center max-w-2xl mx-auto mb-20">
        <span class="text-11 font-mono uppercase tracking-wider text-landing-accent-start bg-landing-accent-start/10 border border-landing-accent-start/20 px-3 py-1 rounded-full">
          Экономика поиска
        </span>
        <h2 class="text-32 md:text-40 font-bold tracking-tight text-white mt-4 font-sans">
          Почувствуй разницу
        </h2>
        <p class="text-14 text-landing-text-muted mt-2">Как изменится твой поиск работы после перехода на Proshli AI</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 mb-16">
        
        {/* The Old Way: Manual */}
        <div class="rounded-3xl border border-white/[0.04] bg-white/[0.01] p-8 relative overflow-hidden group">
          <div class="absolute top-0 right-0 w-16 h-16 bg-red-500/5 rounded-bl-3xl flex items-center justify-center border-l border-b border-white/[0.06]">
            <svg class="w-6 h-6 text-red-500/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12" /></svg>
          </div>
          <h3 class="text-18 font-bold text-white mb-6">Как ищут все</h3>
          
          <ul class="space-y-4 text-13 text-landing-text-muted">
            <li class="flex items-start gap-3">
              <svg class="w-4 h-4 text-red-500/50 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12" /></svg>
              <span>Скроллинг сотен вакансий на hh вручную по 1.5–2 часа в день.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-4 h-4 text-red-500/50 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12" /></svg>
              <span>90% времени тратится на мусорные, нерелевантные или устаревшие позиции.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-4 h-4 text-red-500/50 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12" /></svg>
              <span>Написание сопроводительных писем вручную под каждую вакансию.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-4 h-4 text-red-500/50 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12" /></svg>
              <span>Десятки открытых вкладок браузера, хаос и отсутствие какого-либо трекинга.</span>
            </li>
          </ul>
        </div>

        {/* The New Way: AI Smart (GlowCard client load!) */}
        <GlowCard client:load className="p-8 shadow-[0_0_40px_rgba(124,58,237,0.05)] border-landing-accent-start/30">
          <div class="absolute top-0 right-0 w-16 h-16 bg-landing-accent-start/15 rounded-bl-3xl flex items-center justify-center border-l border-b border-landing-accent-start/20 z-20">
            <svg class="w-6 h-6 text-landing-accent-start" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5" /></svg>
          </div>
          <h3 class="text-18 font-bold text-white mb-6">Как ищешь ты с Proshli AI</h3>
          
          <ul class="space-y-4 text-13 text-landing-text-primary">
            <li class="flex items-start gap-3">
              <svg class="w-4 h-4 text-emerald-400 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5" /></svg>
              <span>Тратишь ровно 2 минуты во время утреннего кофе на просмотр лучших матчей.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-4 h-4 text-emerald-400 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5" /></svg>
              <span>Показатель совпадения (Match-score) гарантирует отбор под твое реальное резюме.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-4 h-4 text-emerald-400 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5" /></svg>
              <span>AI генерирует профессиональное сопроводительное, адаптированное под каждую вакансию.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-4 h-4 text-emerald-400 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5" /></svg>
              <span>Отклики прямо в Telegram. Единая аналитика по откликам в личном кабинете.</span>
            </li>
          </ul>
        </GlowCard>

      </div>

      {/* Calculator Widget */}
      <TimeCalculator client:load />
    </div>
  </section>

  <!-- ═══ How it works: Telegram Mockup ═══ -->
  <section id="how-it-works" class="py-32 px-6 border-t border-white/[0.06]">
    <div class="mx-auto max-w-6xl">
      <div class="max-w-3xl mb-16">
        <span class="text-11 font-mono uppercase tracking-wider text-landing-accent-start bg-landing-accent-start/10 border border-landing-accent-start/20 px-3 py-1 rounded-full">
          Процесс работы
        </span>
        <h2 class="text-32 md:text-48 font-bold tracking-tight text-white mt-4">
          Три простых шага к офферу
        </h2>
      </div>

      <div class="grid md:grid-cols-[1.2fr_1fr] gap-16 items-start">
        {/* Steps */}
        <div class="space-y-6">
          
          <GlowCard client:load className="p-6 transition-all duration-300 group">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-landing-accent-start/10 flex items-center justify-center shrink-0 border border-landing-accent-start/20 group-hover:bg-landing-accent-start/20 transition-all">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-landing-accent-start">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" />
                </svg>
              </div>
              <div>
                <div class="flex items-center gap-3 mb-1.5">
                  <span class="text-11 font-mono text-landing-accent-start/70 uppercase">Шаг 01</span>
                  <h3 class="text-16 font-bold text-white">Загрузи резюме и опиши цель</h3>
                </div>
                <p class="text-13 text-landing-text-muted leading-relaxed">
                  Просто загрузи PDF файл твоего текущего резюме и укажи пожелания: стек, формат (удаленка/офис), локацию и желаемую зарплату. Займет не больше 30 секунд.
                </p>
              </div>
            </div>
          </GlowCard>

          <GlowCard client:load className="p-6 transition-all duration-300 group">
            <div class="flex items-start gap-4">
