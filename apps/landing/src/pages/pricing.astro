---
import BaseLayout from "../layouts/BaseLayout.astro";
import PricingCard from "../components/PricingCard.astro";
import FaqItem from "../components/FaqItem.astro";
import Reveal from "../components/Reveal.tsx";
import { tiers } from "../lib/tiers";
---

<BaseLayout title="Тарифы — Proshli" description="Простые тарифы. Free навсегда, Pro за ₽490/мес, Employer за ₽4 900/мес. Без скрытых платежей.">
  <!-- Hero -->
  <section class="relative py-32 px-6 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_50%_40%_at_50%_0%,rgba(124,58,237,0.12)_0%,transparent_70%)] pointer-events-none"></div>
    <div class="mx-auto max-w-6xl relative">
      <Reveal client:visible>
        <div class="text-center max-w-2xl mx-auto mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-white/10 bg-white/[0.03] mb-6">
            <span class="text-12 text-landing-text-muted">14 дней бесплатно на Pro</span>
          </div>
          <h1 class="text-32 md:text-48 font-extrabold tracking-tight mb-4">
            Простые тарифы,<br />
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-white via-purple-200 to-purple-400">без сюрпризов</span>
          </h1>
          <p class="text-16 text-landing-text-muted max-w-xl mx-auto">Оплата через ЮKassa — карты, СБП, ЮMoney. Отмена в один клик, возврат за 14 дней.</p>
        </div>
      </Reveal>

      <!-- Toggle (future: monthly/yearly) -->
      <div class="grid md:grid-cols-3 gap-6 mb-24">
        {tiers.map((t, i) => (
          <Reveal client:visible delay={i * 0.1}>
            <PricingCard {...t} />
          </Reveal>
        ))}
      </div>

      <!-- Comparison table -->
      <Reveal client:visible>
        <div class="rounded-2xl border border-white/8 bg-white/[0.02] overflow-hidden mb-24">
          <div class="px-6 py-5 border-b border-white/5">
            <h2 class="text-18 font-semibold">Сравнение тарифов</h2>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-14">
              <thead>
                <tr class="border-b border-white/5">
                  <th class="text-left px-6 py-3 text-landing-text-muted font-normal">Функция</th>
                  <th class="px-6 py-3 text-center font-medium">Free</th>
                  <th class="px-6 py-3 text-center font-medium text-landing-accent-start">Pro</th>
                  <th class="px-6 py-3 text-center font-medium">Employer</th>
                </tr>
              </thead>
              <tbody class="text-13 text-landing-text-muted">
                <tr class="border-b border-white/5">
                  <td class="px-6 py-3">AI-запросы</td>
                  <td class="px-6 py-3 text-center">3 / день</td>
                  <td class="px-6 py-3 text-center text-white font-medium">Безлимит</td>
                  <td class="px-6 py-3 text-center text-white font-medium">Безлимит</td>
                </tr>
                <tr class="border-b border-white/5">
                  <td class="px-6 py-3">Дайджест</td>
                  <td class="px-6 py-3 text-center">Раз в неделю</td>
                  <td class="px-6 py-3 text-center text-white font-medium">Каждый день</td>
                  <td class="px-6 py-3 text-center text-white font-medium">Каждый день</td>
                </tr>
                <tr class="border-b border-white/5">
                  <td class="px-6 py-3">Match-score</td>
                  <td class="px-6 py-3 text-center">Базовый</td>
                  <td class="px-6 py-3 text-center text-white font-medium">С обоснованием</td>
                  <td class="px-6 py-3 text-center text-white font-medium">С обоснованием</td>
                </tr>
                <tr class="border-b border-white/5">
                  <td class="px-6 py-3">AI-улучшение резюме</td>
                  <td class="px-6 py-3 text-center">
                    <svg class="w-4 h-4 mx-auto text-white/20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12" /></svg>
                  </td>
                  <td class="px-6 py-3 text-center">
                    <svg class="w-4 h-4 mx-auto text-landing-accent-start" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12" /></svg>
                  </td>
                  <td class="px-6 py-3 text-center">
                    <svg class="w-4 h-4 mx-auto text-landing-accent-start" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12" /></svg>
                  </td>
                </tr>
                <tr class="border-b border-white/5">
                  <td class="px-6 py-3">Публикация вакансий</td>
                  <td class="px-6 py-3 text-center">
                    <svg class="w-4 h-4 mx-auto text-white/20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12" /></svg>
                  </td>
                  <td class="px-6 py-3 text-center">
                    <svg class="w-4 h-4 mx-auto text-white/20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12" /></svg>
                  </td>
                  <td class="px-6 py-3 text-center">
                    <svg class="w-4 h-4 mx-auto text-landing-accent-start" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12" /></svg>
                  </td>
                </tr>
                <tr>
                  <td class="px-6 py-3">Команда</td>
                  <td class="px-6 py-3 text-center">1</td>
                  <td class="px-6 py-3 text-center">1</td>
                  <td class="px-6 py-3 text-center text-white font-medium">До 5</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </Reveal>

      <!-- FAQ -->
      <Reveal client:visible>
        <h2 class="text-24 font-bold mb-8">Часто задают про оплату</h2>
      </Reveal>
      <div class="space-y-3 max-w-3xl">
        <Reveal client:visible delay={0.05}>
          <FaqItem question="Что входит в Free?">
            3 AI-запроса в день, еженедельный дайджест, базовый match-score. Без ограничения по времени.
          </FaqItem>
        </Reveal>
        <Reveal client:visible delay={0.1}>
          <FaqItem question="Как работает биллинг?">
            Через ЮKassa. Принимаем карты, СБП, ЮMoney. Чек на email автоматически.
          </FaqItem>
        </Reveal>
        <Reveal client:visible delay={0.15}>
          <FaqItem question="Возврат?">
            В течение 14 дней — полный возврат. После — пропорционально оставшимся дням.
          </FaqItem>
        </Reveal>
        <Reveal client:visible delay={0.2}>
          <FaqItem question="Есть триал для Pro?">
            Пока нет отдельного триала — Free-тариф и есть триал. Попробуй, и если 3 запросов мало — переходи на Pro.
          </FaqItem>
        </Reveal>
      </div>
    </div>
  </section>
</BaseLayout>
