---
import BaseLayout from "../layouts/BaseLayout.astro";
import AnimatedCounter from "../components/AnimatedCounter.tsx";
---

<BaseLayout title="Для работодателей — Proshli" description="AI-скрининг кандидатов. Видишь только тех, кто реально подходит — без ручной разборки сотен резюме.">
  <!-- Hero Section -->
  <section class="relative py-32 px-6 overflow-hidden">
    {/* Deep Blue-Cyan Gradient Background */}
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_0%,rgba(14,165,233,0.1)_0%,transparent_80%)] pointer-events-none"></div>
    
    <div class="mx-auto max-w-6xl relative z-10">
      
      <div class="max-w-3xl mb-20">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-sky-500/20 bg-sky-500/5 mb-6">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-sky-400"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
          <span class="text-11 font-mono uppercase tracking-wider text-sky-400">Employer-тариф</span>
        </div>
        
        <h1 class="text-36 md:text-56 font-bold tracking-tight text-white leading-tight">
          AI делает first-pass скрининг<br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-400 to-emerald-400">
            за вашего HR-специалиста
          </span>
        </h1>
        <p class="mt-6 text-16 md:text-18 text-landing-text-muted leading-relaxed max-w-2xl">
          Сэкономьте до 80% времени на разборе откликов. AI анализирует резюме соискателей по смыслу, выстраивает рейтинг кандидатов по совпадению со стеком и пропускает только лучших.
        </p>
      </div>

      <!-- Stats Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-24">
        <div class="rounded-2xl border border-white/[0.05] bg-gradient-to-b from-white/[0.02] to-transparent p-6 hover:border-sky-500/20 hover:shadow-[0_0_35px_rgba(14,165,233,0.02)] transition-all duration-300">
          <div class="text-48 font-bold font-mono text-sky-400 leading-none">
            <AnimatedCounter client:visible target={85} suffix="%" />
          </div>
          <div class="text-12 text-landing-text-muted mt-2 uppercase tracking-wider font-mono">точность AI-скрининга</div>
        </div>

        <div class="rounded-2xl border border-white/[0.05] bg-gradient-to-b from-white/[0.02] to-transparent p-6 hover:border-sky-500/20 hover:shadow-[0_0_35px_rgba(14,165,233,0.02)] transition-all duration-300">
          <div class="text-48 font-bold font-mono text-sky-400 leading-none">
            <AnimatedCounter client:visible target={12} suffix="x" />
          </div>
          <div class="text-12 text-landing-text-muted mt-2 uppercase tracking-wider font-mono">быстрее ручной обработки</div>
        </div>

        <div class="rounded-2xl border border-white/[0.05] bg-gradient-to-b from-white/[0.02] to-transparent p-6 hover:border-sky-500/20 hover:shadow-[0_0_35px_rgba(14,165,233,0.02)] transition-all duration-300">
          <div class="text-48 font-bold font-mono text-sky-400 leading-none">
            <AnimatedCounter client:visible target={2400} suffix="+" separator=" " />
          </div>
          <div class="text-12 text-landing-text-muted mt-2 uppercase tracking-wider font-mono">IT-кандидатов в базе</div>
        </div>
      </div>

      <!-- Features grid -->
      <div class="grid md:grid-cols-[1.4fr_1fr] gap-6 mb-24">
        
        {/* Highlight Feature Card */}
        <div class="rounded-3xl border border-white/[0.05] bg-gradient-to-b from-white/[0.02] to-transparent p-8 hover:border-sky-500/20 transition-all duration-300 flex flex-col justify-between relative group">
          <div class="absolute -top-12 -right-12 w-64 h-64 bg-sky-500/5 rounded-full blur-[60px] pointer-events-none group-hover:bg-sky-500/10 transition-all duration-500"></div>
          
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 rounded-xl bg-sky-500/10 border border-sky-500/20 flex items-center justify-center shrink-0">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-sky-400">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" />
              </svg>
            </div>
            <div>
              <h3 class="text-22 font-bold text-white tracking-tight">Кандидаты с семантическим Match-score</h3>
              <p class="text-14 text-landing-text-muted leading-relaxed mt-2.5">
                Забудьте о фильтрации по ключевым словам. Наша система сравнивает математическое описание требований вакансии с резюме кандидата. Вы сразу видите детальный процент совпадения и текстовое обоснование: в чем соискатель идеален, а в каких технологиях у него пробелы.
              </p>
            </div>
          </div>

          <div class="mt-8 border border-white/[0.06] rounded-2xl bg-black/40 p-5 font-mono text-12 text-white/80 space-y-2">
            <div class="flex items-center justify-between border-b border-white/[0.04] pb-2">
              <span class="font-bold text-white">Кандидат: Дмитрий П. (Go Developer)</span>
              <span class="text-emerald-400 font-bold bg-emerald-500/10 px-2 py-0.5 rounded border border-emerald-500/20">92% Match</span>
            </div>
            <div class="pt-1">
              <span class="text-sky-400 font-semibold">• Стек совпадений:</span> Go (4 года), Kafka (опыт в highload), PostgreSQL.
            </div>
            <div>
              <span class="text-yellow-400 font-semibold">• Внимание:</span> В требованиях указан ClickHouse, у соискателя опыт только с PostgreSQL/Elasticsearch.
            </div>
          </div>
        </div>

        {/* Small feature cards */}
        <div class="flex flex-col gap-6">
          <div class="rounded-3xl border border-white/[0.05] bg-gradient-to-b from-white/[0.02] to-transparent p-6 hover:border-emerald-500/20 transition-all duration-300 relative overflow-hidden">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-emerald-400"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" /></svg>
              </div>
              <div>
                <h3 class="text-16 font-bold text-white">Мгновенный скрининг</h3>
                <p class="text-13 text-landing-text-muted leading-relaxed mt-1">
                  AI отбирает и структурирует резюме за секунды. Никакого ручного разбора завалов на почте.
                </p>
              </div>
            </div>
          </div>

          <div class="rounded-3xl border border-white/[0.05] bg-gradient-to-b from-white/[0.02] to-transparent p-6 hover:border-sky-500/20 transition-all duration-300 relative overflow-hidden">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-sky-500/10 border border-sky-500/20 flex items-center justify-center shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-sky-400"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
              </div>
              <div>
                <h3 class="text-16 font-bold text-white">Командный аккаунт</h3>
                <p class="text-13 text-landing-text-muted leading-relaxed mt-1">
                  Подключайте до 5 рекрутеров и нанимающих менеджеров в рамках единого тарифа.
                </p>
              </div>
            </div>
          </div>
        </div>

      </div>

      {/* How it works for employers */}
      <div class="rounded-3xl border border-white/[0.05] bg-gradient-to-b from-white/[0.02] to-transparent p-8 mb-24 relative overflow-hidden">
        <h2 class="text-20 font-bold text-white mb-8 tracking-tight">Как устроен процесс найма</h2>
        
        <div class="grid md:grid-cols-3 gap-8">
          <div class="flex gap-4">
            <div class="text-32 font-bold font-mono text-sky-500/20 leading-none">01</div>
            <div>
              <h3 class="text-14 font-bold text-white">Создайте или импортируйте вакансию</h3>
              <p class="text-13 text-landing-text-muted leading-relaxed mt-1">Заполните стек и условия или в один клик импортируйте вакансию с hh.ru.</p>
            </div>
          </div>
          
          <div class="flex gap-4">
            <div class="text-32 font-bold font-mono text-sky-500/20 leading-none">02</div>
            <div>
              <h3 class="text-14 font-bold text-white">AI фильтрует базу резюме</h3>
              <p class="text-13 text-landing-text-muted leading-relaxed mt-1">Система автоматически ранжирует специалистов по соответствию требованиям.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="text-32 font-bold font-mono text-sky-500/20 leading-none">03</div>
            <div>
              <h3 class="text-14 font-bold text-white">Получайте отклики со скринингом</h3>
              <p class="text-13 text-landing-text-muted leading-relaxed mt-1">Открывайте дашборд с готовыми карточками соискателей и связывайтесь с ними напрямую.</p>
            </div>
          </div>
        </div>
      </div>

      {/* Employer CTA */}
      <div class="rounded-3xl bg-gradient-to-br from-sky-500/15 via-[#0a0f18] to-[#07070a] border border-sky-500/35 p-10 md:p-16 relative overflow-hidden shadow-[0_0_50px_rgba(14,165,233,0.1)]">
        <div class="absolute -top-24 -right-24 w-96 h-96 bg-sky-500/10 rounded-full blur-[80px] pointer-events-none"></div>
        
        <div class="relative flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
          <div>
            <span class="text-28 md:text-36 font-bold text-white font-mono">₽4 900 <span class="text-14 text-landing-text-muted font-sans font-normal">/ месяц</span></span>
            <p class="text-13 text-landing-text-muted mt-2 max-w-md">14 дней бесплатного полнофункционального триала. Банковская карта не требуется.</p>
          </div>
          
          <a
            href="https://app.proshli.ru/employer/onboarding"
            class="inline-flex items-center justify-center h-12 px-8 rounded-xl bg-gradient-to-r from-sky-500 to-sky-400 text-14 font-semibold text-white shadow-lg shadow-sky-500/10 hover:opacity-90 active:scale-[0.98] transition-all duration-200 shrink-0"
          >
            Начать бесплатный триал
            <svg class="ml-2 w-4.5 h-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
          </a>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>
