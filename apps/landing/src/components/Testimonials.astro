---
/**
 * Social proof section: testimonials + trust metrics.
 * Avatars are CSS-generated initials (no external images).
 */
const testimonials = [
  {
    name: "Дмитрий К.",
    role: "Go-разработчик, ex-Ozon",
    initials: "ДК",
    color: "from-violet-500 to-purple-600",
    text: "Подписался на Pro после первого дайджеста. За неделю получил 3 приглашения на собес — все релевантные, не как на hh где 90% мусора.",
  },
  {
    name: "Анна М.",
    role: "Data Engineer, Тинькофф",
    initials: "АМ",
    color: "from-blue-500 to-cyan-500",
    text: "Наконец-то не надо каждый вечер листать вакансии. Бот присылает топ-5 утром, я трачу 2 минуты вместо часа. Матч-скор реально работает.",
  },
  {
    name: "Сергей Л.",
    role: "TeamLead Backend, стартап",
    initials: "СЛ",
    color: "from-emerald-500 to-teal-500",
    text: "Использую Employer-тариф. AI-скрининг отсеивает нерелевантных кандидатов — экономит часы HR-менеджеру. Интеграция с Telegram удобнее почты.",
  },
];
---

<section class="py-32 px-6 border-t border-white/5">
  <div class="mx-auto max-w-6xl">
    <!-- Trust bar -->
    <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-4 mb-20">
      <div class="flex items-center gap-2 text-landing-text-muted">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-landing-accent-start">
          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" />
        </svg>
        <span class="text-14"><span class="text-white font-semibold">2 400+</span> пользователей</span>
      </div>
      <div class="flex items-center gap-2 text-landing-text-muted">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-landing-accent-start">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
        </svg>
        <span class="text-14"><span class="text-white font-semibold">180K+</span> дайджестов отправлено</span>
      </div>
      <div class="flex items-center gap-2 text-landing-text-muted">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-landing-accent-start">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
        </svg>
        <span class="text-14"><span class="text-white font-semibold">4.8</span> средняя оценка</span>
      </div>
    </div>

    <!-- Testimonial cards -->
    <div class="grid md:grid-cols-3 gap-5">
      {testimonials.map((t) => (
        <div class="rounded-xl border border-white/8 bg-white/[0.02] p-6 hover:border-white/15 transition-colors">
          <div class="flex items-center gap-3 mb-4">
            <div class:list={["w-10 h-10 rounded-full bg-gradient-to-br flex items-center justify-center text-12 font-bold text-white shrink-0", t.color]}>
              {t.initials}
            </div>
            <div>
              <div class="text-14 font-semibold text-white">{t.name}</div>
              <div class="text-12 text-landing-text-muted">{t.role}</div>
            </div>
          </div>
          <p class="text-14 text-landing-text-muted leading-relaxed">{t.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
