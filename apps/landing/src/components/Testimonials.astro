---
/**
 * Social proof section: testimonials + trust metrics.
 * Avatars are CSS-generated initials (no external images).
 */
const testimonials = [
  {
    name: "Дмитрий К.",
    role: "Go-разработчик, ex-Ozon",
    initials: "ДК",
    color: "from-violet-500 to-indigo-600",
    rating: 5,
    text: "Подписался на Pro после первого дайджеста. За неделю получил 3 приглашения на собеседование — все релевантные, не как на hh, где 90% спама и неразобранных вакансий.",
  },
  {
    name: "Анна М.",
    role: "Data Engineer, Т-Банк",
    initials: "АМ",
    color: "from-blue-500 to-cyan-500",
    rating: 5,
    text: "Наконец-то не надо каждый вечер вручную листать вакансии и фильтровать мусор. Бот присылает топ-5 утром, я трачу 2 минуты за кофе вместо часа. Алгоритм матчинга работает на 10/10.",
  },
  {
    name: "Сергей Л.",
    role: "TeamLead Backend, стартап",
    initials: "СЛ",
    color: "from-emerald-500 to-teal-500",
    rating: 5,
    text: "Использую Employer-тариф для поиска людей. AI-скрининг отсеивает нерелевантных кандидатов и экономит десятки часов нашему HR-департаменту. Отклик прямо в Telegram — это гениально.",
  },
];
---

<section class="py-32 px-6 border-t border-white/[0.06] relative overflow-hidden">
  {/* Soft background glow */}
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] rounded-full bg-landing-accent-start/5 blur-[120px] pointer-events-none"></div>

  <div class="mx-auto max-w-6xl relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-20">
      <h2 class="text-24 md:text-36 font-bold tracking-tight mb-4">
        Каждый день помогаем экономить<br />
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-white via-purple-200 to-purple-400">тысячи часов поиска</span>
      </h2>
      <p class="text-14 text-landing-text-muted">Отзывы специалистов и работодателей, которые уже автоматизировали свой найм и поиск.</p>
    </div>

    <!-- Trust bar (Glassmorphism row) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto mb-20">
      <div class="flex items-center gap-4 px-6 py-5 rounded-2xl border border-white/[0.05] bg-gradient-to-b from-white/[0.02] to-transparent hover:border-white/10 transition-colors">
        <div class="w-10 h-10 rounded-xl bg-landing-accent-start/15 flex items-center justify-center shrink-0 border border-landing-accent-start/20">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-landing-accent-start">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" />
          </svg>
        </div>
        <div>
          <div class="text-18 font-bold font-mono text-white leading-none">2 400+</div>
          <span class="text-12 text-landing-text-muted mt-1 block">активных пользователей</span>
        </div>
      </div>

      <div class="flex items-center gap-4 px-6 py-5 rounded-2xl border border-white/[0.05] bg-gradient-to-b from-white/[0.02] to-transparent hover:border-white/10 transition-colors">
        <div class="w-10 h-10 rounded-xl bg-landing-accent-start/15 flex items-center justify-center shrink-0 border border-landing-accent-start/20">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-landing-accent-start">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
          </svg>
        </div>
        <div>
          <div class="text-18 font-bold font-mono text-white leading-none">180 000+</div>
          <span class="text-12 text-landing-text-muted mt-1 block">дайджестов отправлено</span>
        </div>
      </div>

      <div class="flex items-center gap-4 px-6 py-5 rounded-2xl border border-white/[0.05] bg-gradient-to-b from-white/[0.02] to-transparent hover:border-white/10 transition-colors">
        <div class="w-10 h-10 rounded-xl bg-landing-accent-start/15 flex items-center justify-center shrink-0 border border-landing-accent-start/20">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-landing-accent-start">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
          </svg>
        </div>
        <div>
          <div class="text-18 font-bold font-mono text-white leading-none">4.8 / 5.0</div>
          <span class="text-12 text-landing-text-muted mt-1 block">средняя оценка бота</span>
        </div>
      </div>
    </div>

    <!-- Testimonial cards -->
    <div class="grid md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="rounded-2xl border border-white/[0.05] bg-gradient-to-b from-white/[0.02] to-transparent p-6 hover:border-white/15 transition-all duration-300 hover:shadow-[0_0_30px_rgba(124,58,237,0.02)] group hover:-translate-y-1">
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
              <div class:list={["w-10 h-10 rounded-full bg-gradient-to-br flex items-center justify-center text-12 font-bold text-white shrink-0 border border-white/10 shadow-sm", t.color]}>
                {t.initials}
              </div>
              <div>
                <div class="text-13 font-semibold text-white leading-tight">{t.name}</div>
                <div class="text-11 text-landing-text-muted mt-0.5">{t.role}</div>
              </div>
            </div>
          </div>
          
          {/* Star rating row */}
          <div class="flex gap-1 mb-3">
            {Array.from({ length: t.rating }).map(() => (
              <svg class="w-3.5 h-3.5 text-yellow-500/80 fill-yellow-500/20" viewBox="0 0 24 24">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
              </svg>
            ))}
          </div>

          <p class="text-13 text-landing-text-muted leading-relaxed group-hover:text-white/80 transition-colors">{t.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
