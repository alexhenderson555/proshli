---
import GlowCard from "./GlowCard.tsx";

interface Props {
  name: string;
  price: string;
  period: string;
  features: string[];
  cta: string;
  ctaHref: string;
  featured?: boolean;
}
const { name, price, period, features, cta, ctaHref, featured = false } = Astro.props;
---

<GlowCard 
  client:load 
  className={featured
    ? "bg-gradient-to-b from-landing-accent-start/10 via-[#0e0e11] to-[#0a0a0c] border border-landing-accent-start/40 shadow-[0_0_50px_rgba(124,58,237,0.1)] p-8"
    : "bg-gradient-to-b from-white/[0.02] via-[#0c0c0e] to-[#0a0a0c] border border-white/[0.06] p-8"
  }
>
  <!-- Top glow lines -->
  {featured && (
    <div class="absolute top-0 left-10 right-10 h-[1px] bg-gradient-to-r from-transparent via-landing-accent-start to-transparent blur-[1px] z-20"></div>
    <div class="absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-landing-accent-end/60 to-transparent z-20"></div>
  )}

  {featured && (
    <div class="absolute top-4 right-4 bg-landing-accent-start/15 border border-landing-accent-start/30 text-landing-accent-start text-10 font-bold px-2.5 py-1 rounded-full tracking-wide uppercase z-20">
      Популярный
    </div>
  )}
  
  <div class="mb-6 relative z-10">
    <span class="text-11 font-mono uppercase tracking-wider text-landing-text-muted/80">{name}</span>
    <div class="flex items-baseline gap-2 mt-2">
      <span class:list={["text-48 font-bold tracking-tight text-white"]}>
        {price}
      </span>
      <span class="text-14 text-landing-text-muted">/ {period}</span>
    </div>
  </div>

  <div class="h-[1px] bg-white/[0.06] w-full mb-6 relative z-10"></div>

  <ul class="space-y-4 text-14 mb-8 flex-grow relative z-10">
    {features.map((f) => (
      <li class="flex items-start gap-3 text-landing-text-muted transition-colors duration-200">
        <div class:list={[
          "w-5 h-5 rounded-full flex items-center justify-center shrink-0 mt-0.5 border",
          featured 
            ? "border-landing-accent-start/30 bg-landing-accent-start/10 text-landing-accent-start" 
            : "border-white/10 bg-white/[0.03] text-white/40"
        ]}>
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
            <polyline points="20 6 9 17 4 12" />
          </svg>
        </div>
        <span class="leading-snug text-13">{f}</span>
      </li>
    ))}
  </ul>

  <a
    href={ctaHref}
    class:list={[
      "block text-center rounded-xl h-11 leading-[2.75rem] text-13 font-semibold transition-all duration-200 select-none relative z-10",
      featured
        ? "bg-gradient-to-r from-landing-accent-start to-landing-accent-end text-white hover:opacity-90 active:scale-[0.98] shadow-glow"
        : "border border-white/10 text-white bg-white/[0.02] hover:bg-white/[0.06] hover:border-white/20 active:scale-[0.98]",
    ]}
  >
    {cta}
  </a>
</GlowCard>
