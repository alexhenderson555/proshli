---
interface Props {
  name: string;
  price: string;
  period: string;
  features: string[];
  cta: string;
  ctaHref: string;
  featured?: boolean;
}
const { name, price, period, features, cta, ctaHref, featured = false } = Astro.props;
---

<div class:list={[
  "rounded-xl p-7 flex flex-col",
  featured
    ? "bg-gradient-to-br from-landing-accent-start/15 to-landing-accent-end/5 border-2 border-landing-accent-start/60 shadow-glow"
    : "bg-white/[0.02] border border-white/8",
]}>
  {featured && <div class="text-11 uppercase tracking-wider font-bold text-landing-accent-start mb-3">Популярный</div>}
  <h3 class="text-20 font-bold mb-1">{name}</h3>
  <div class="flex items-baseline gap-1 mb-6">
    <span class="text-32 font-bold">{price}</span>
    <span class="text-13 text-landing-text-muted">/ {period}</span>
  </div>
  <ul class="space-y-2.5 text-14 mb-8 flex-grow">
    {features.map((f) => (
      <li class="text-landing-text-muted pl-4 relative before:content-['—'] before:absolute before:left-0 before:text-white/20">
        {f}
      </li>
    ))}
  </ul>
  <a
    href={ctaHref}
    class:list={[
      "block text-center rounded-lg h-10 leading-[2.5rem] text-13 font-medium transition-all",
      featured
        ? "bg-gradient-to-r from-landing-accent-start to-landing-accent-end text-white hover:opacity-90"
        : "border border-white/15 text-white hover:bg-white/5",
    ]}
  >
    {cta}
  </a>
</div>
