---
interface Props {
  name: string;
  price: string;
  period: string;
  features: string[];
  cta: string;
  ctaHref: string;
  featured?: boolean;
}
const { name, price, period, features, cta, ctaHref, featured = false } = Astro.props;
---

<div class:list={[
  "rounded-2xl p-7 flex flex-col relative overflow-hidden transition-all duration-300 hover:translate-y-[-2px]",
  featured
    ? "bg-gradient-to-br from-landing-accent-start/15 to-landing-accent-end/5 border-2 border-landing-accent-start/60 shadow-glow"
    : "bg-white/[0.02] border border-white/8 hover:border-white/15",
]}>
  {featured && (
    <div class="absolute top-0 right-0 bg-gradient-to-l from-landing-accent-start to-landing-accent-end text-11 font-bold text-white px-4 py-1 rounded-bl-lg tracking-wide uppercase">
      Популярный
    </div>
  )}
  <div class="mb-6">
    <h3 class="text-18 font-bold mb-1">{name}</h3>
    <div class="flex items-baseline gap-1.5">
      <span class:list={["text-36 font-bold", featured && "bg-clip-text text-transparent bg-gradient-to-r from-landing-accent-start to-landing-accent-end"]}>{price}</span>
      <span class="text-13 text-landing-text-muted">/ {period}</span>
    </div>
  </div>
  <ul class="space-y-3 text-14 mb-8 flex-grow">
    {features.map((f) => (
      <li class="flex items-start gap-2.5 text-landing-text-muted">
        <svg class:list={["w-4 h-4 mt-0.5 shrink-0", featured ? "text-landing-accent-start" : "text-white/30"]} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="20 6 9 17 4 12" />
        </svg>
        <span>{f}</span>
      </li>
    ))}
  </ul>
  <a
    href={ctaHref}
    class:list={[
      "block text-center rounded-lg h-11 leading-[2.75rem] text-14 font-medium transition-all",
      featured
        ? "bg-gradient-to-r from-landing-accent-start to-landing-accent-end text-white hover:opacity-90 shadow-glow"
        : "border border-white/15 text-white hover:bg-white/5 hover:border-white/25",
    ]}
  >
    {cta}
  </a>
</div>
