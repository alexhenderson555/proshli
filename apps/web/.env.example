# ---------------------------------------------------------------------------
# Otklik.ai — Web environment template.
# Copy to `apps/web/.env.local` for local dev (Next.js auto-loads it).
# Wave 10 will switch to `@t3-oss/env-nextjs` to validate these at boot.
# ---------------------------------------------------------------------------

# --- Public (NEXT_PUBLIC_*) — shipped to the browser. ----------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# ЮKassa publishable parts (used for inline checkout widget in Wave 2+).
NEXT_PUBLIC_YOOKASSA_SHOP_ID=

# --- Server-only ------------------------------------------------------------
# Anything not prefixed with NEXT_PUBLIC_ stays on the server.
SENTRY_AUTH_TOKEN=
