# ---------------------------------------------------------------------------
# Proshli — Telegram bot environment template.
# Bot is its own process — minimal env, talks to the FastAPI backend.
# Wave 5 will harden this with Redis state + SSE consumption.
# ---------------------------------------------------------------------------

# Token from @BotFather.
PROSHLI_BOT_TOKEN=

# Base URL of the Proshli API — http for local dev, https for prod.
PROSHLI_API_URL=http://127.0.0.1:8000

# Service key for server→server endpoints (must match API's BOT_SERVICE_KEY).
PROSHLI_BOT_SERVICE_KEY=change-me-bot-service-key

# Redis for chat-state persistence (Wave 5 replaces the in-memory dict).
PROSHLI_REDIS_URL=redis://localhost:6379/3

# Optional Sentry DSN.
SENTRY_DSN=
