# ---------------------------------------------------------------------------
# Otklik.ai — Workers (Celery) environment template.
# Mirrors the API .env — workers re-use ``app.config.settings`` to stay in
# sync (single source of truth). Wave 4 will add embedding-provider keys.
# ---------------------------------------------------------------------------

APP_ENV=development
APP_LOG_LEVEL=INFO

# --- Database / Redis -------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://otklik:otklik@localhost:5432/otklik
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Anthropic Claude (Wave 3) ---------------------------------------------
ANTHROPIC_API_KEY=

# --- ЮKassa (so worker tasks can finalize subscription syncs) --------------
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# --- Ingestion sources ------------------------------------------------------
RSS_SOURCE_URLS=
HH_BASE_URL=https://api.hh.ru
HH_SEARCH_TEXT=python developer
HH_REGION=113
HH_PER_PAGE=20
HH_LIVE_ENABLED=true
HH_LIVE_LIMIT=30

# --- Observability ----------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
