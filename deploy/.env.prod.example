# Proshli — production .env template.
# Copy to ./.env.prod on the VPS and fill the placeholders. Never commit
# the resulting .env.prod — it's already in .gitignore.

# === Required ================================================================

# Domain (without protocol). Caddy uses this for TLS + the Next.js public URL.
PROSHLI_DOMAIN=proshli.ru

# Postgres credentials (only used during initial docker-compose up).
POSTGRES_USER=proshli
POSTGRES_PASSWORD=CHANGE_ME_pg_password
POSTGRES_DB=proshli

# JWT signing secret — must be ≥32 random bytes. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_jwt_secret

# Service key shared between API and tgbot for /internal/* endpoints.
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
BOT_SERVICE_KEY=CHANGE_ME_bot_service_key

# === Telegram ================================================================

# Token from @BotFather.
TELEGRAM_BOT_TOKEN=
# Your personal user_id (find via @userinfobot) — receives approval DMs.
TELEGRAM_ADMIN_CHAT_ID=
# Channel chat_id (negative, e.g. -100xxx) where approved vacancies post.
TELEGRAM_PUBLICATION_CHANNEL_ID=
# Supergroup chat_id where the firehose posts.
TELEGRAM_PUBLICATION_GROUP_ID=
# Top-N candidates surfaced in the daily DM.
CHANNEL_APPROVAL_TOP_N=8

# tgbot reads these same vars under PROSHLI_* names.
PROSHLI_BOT_TOKEN=${TELEGRAM_BOT_TOKEN}
PROSHLI_BOT_SERVICE_KEY=${BOT_SERVICE_KEY}

# === Anthropic (via Tokenator proxy) =========================================

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.tokenator.cloud/anthropic
ANTHROPIC_MODEL=claude-opus-4-6
ANTHROPIC_MAX_TOKENS=1024

# === ЮKassa (recurring billing) ==============================================

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# === Voyage embeddings (semantic search) =====================================

VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

# === Ingestion ===============================================================

HH_BASE_URL=https://api.hh.ru
HH_SEARCH_TEXT=python developer
HH_REGION=113
HH_PER_PAGE=20
HH_LIVE_ENABLED=true
HH_LIVE_LIMIT=30
RSS_SOURCE_URLS=

# === Observability ===========================================================

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# === CORS / Trusted proxies ==================================================

CORS_ALLOWED_ORIGINS=https://proshli.ru,https://www.proshli.ru
# Caddy sits in front in the docker network → trust its forwarded headers.
# 172.16.0.0/12 covers Docker's default bridge network.
TRUSTED_PROXIES=172.16.0.0/12

# === SMTP (transactional email) ==============================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@proshli.ru
